<idea-plugin>
    <id>com.github.kassett.excelEditor</id>
    <name>Excel Editor</name>
    <vendor>Kassett</vendor>

    <description>
        <![CDATA[
        Opens Excel workbooks in a read-only IntelliJ editor tab.
        ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="com.github.kassett.exceleditor.editor.ExcelFileEditorProvider"/>
    </extensions>
</idea-plugin>
